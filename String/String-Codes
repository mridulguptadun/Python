12. Find Duplicate Characters

    text = input("Enter String: ")
    visited = ""
    for ch in text:
        if ch not in visited:
            if text.count(ch) > 1:
                print(ch)
            visited += ch

13. Character Frequency

    text = input("Enter String: ")
    visited = ""
    for ch in text:
        if ch not in visited:
            print(ch, "=", text.count(ch))
            visited += ch

