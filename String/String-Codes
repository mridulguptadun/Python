18. Largest Word

    text = input("Sentence: ")
    words = text.split()
    largest = ""
    for word in words:
        if len(word) > len(largest):
            largest = word
    print(largest)

19. Smallest Word

    text = input("Sentence: ")
    words = text.split()
    smallest = words[0]
    for word in words:
        if len(word) < len(smallest):
            smallest = word
    print(smallest)

