import json
def load_data():
	with open("students.json", "r") as file:
		return json.load(file)

def save_data(data):
	with open("students.json", "w") as file:
		json.dump(data, file, indent=4)

def add_student():
	students = load_data()
	student = {
		"id" : input("Enter ID : "),
		"name" : input("Enter Name : "),
		"age" : int(input("Enter Age : "))
	}
	students.append(student)
	save_data(students)
	print("Students Added Successfully!")

def view_students():
	students = load_data()

	if not students:
		print("No Student Found")
		return

	for std in students:
		print("-" * 30)
		print("ID : ", std["id"])
		print("Name : ", std["name"])
		print("Age : ", std["age"])

def search_student():
	students = load_data()
	sid = input("Enter Student ID : ")

	for std in students:
		if std["id"] == sid:
			print(std)
			return
	print("Student Not Found")

def delete_student():
	students = load_data()
	sid = input("Enter Student Id : ")
	for std in students:
		if std["id"] == sid:
			students.remove(std)
			save_data(students)
			print("Deleted Successfully")
	print("Student Not Found")

def update_student():
	students = load_data()
	sid = input("Enter Student Id : ")
	for std in students:
		if std["id"] == sid:
			std["name"] = input("Enter New Name :")
			std["age"] = int(input("Enter New Age : "))
			save_data(students)
			print("Update Successfully")
			return
	print("Student Not Found")

