👉 Spy Number -> 123 -> 1+2+3 = 6 and 1 * 2 * 3 = 6

	n = int(input("Enter a Number : "))
	t = n
	s = 0
	p = 1
	
	while t > 0:
		d = t % 10
		s += d
		p *= d
		t //=10
	
	if s == p:
		print(n, "Is a Spy Number")
	else:
		print(n, "Not a Spy Number")


