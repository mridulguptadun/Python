👉 Palindrome number

    n = int(input("Enter Any No : "))
    t = n
    rev = 0
    while t > 0:
    	r = t % 10                               
    	rev = (rev * 10) + r
    	t = t//10
    if (n == rev):
    	print("Palindrome")
    else:
    	print("Not A Palindrome")
    
