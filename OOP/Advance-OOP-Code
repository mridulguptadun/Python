Example 4 (Best for Practice): School Management System

class Student:

    def __init__(self, name, roll):
        self.name = name
        self.roll = roll

class School:

    def __init__(self):
        self.students = []

    def add_student(self, student):
        self.students.append(student)

    def search(self, roll):

        for s in self.students:

            if s.roll == roll:
                print(s.name)
                return

        print("Student Not Found")

    def show(self):

        for s in self.students:
            print(s.roll, s.name)

school = School()

school.add_student(Student("Aman", 1))
school.add_student(Student("Rahul", 2))
school.add_student(Student("Priya", 3))
school.show()
school.search(2)

