Example 3: Employee Salary (Class Variable + Static Method)

    class Employee:
    
        company = "Google"
    
        def __init__(self, name, salary):
            self.name = name
            self.salary = salary
    
        @staticmethod
        def company_info():
            print("Welcome to Google")
    
        def annual_salary(self):
            return self.salary * 12
    
        def display(self):
            print("Name :", self.name)
            print("Salary :", self.salary)
            print("Annual Salary :", self.annual_salary())
    
    Employee.company_info()
    
    e1 = Employee("Aman", 50000)
    e2 = Employee("Rahul", 70000)
    
    e1.display()
    print()
    e2.display()

Concepts Used
👉 Static Method
👉 Class Variable
👉 Instance Variable

